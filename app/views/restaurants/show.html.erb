<%= render "nav" %>
<div class="m-3">
  <p>
    <strong>Name:</strong>
    <%= @restaurant.name %>
  </p>

  <p>
    <strong>Address:</strong>
    <%= @restaurant.address %>
  </p>

  <p>
    <strong>Category :</strong>
    <%= @restaurant.category %>
  </p>

  <p>
    <strong>Reviews :</strong>
    <ul>
      <% @reviews.each do |review| %>
      <li> <%= review.content %> <strong> <%= "Note :" %></strong> <%= review.rating %> <%= "⭐" %> </li>
      <% end %>
    </ul>
  </p>
  <div class="container col-lg-4 mt-4">
    <h3>Création d'une review pour : <%= @restaurant.name %> </h3>

  	<%= simple_form_for [@restaurant, @review] do |f| %>
		<%= f.input :content %>
    <%= f.input :rating, collection: 0..5 %>
		<%= f.button :submit, class: "text-white btn btn-secondary" %>
	<% end %>
  </div>
</div>
